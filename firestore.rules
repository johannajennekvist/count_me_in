rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.createdBy;
      // Anyone signed in can join (adds only their own uid to memberIds).
      // Any current member can leave on their own (memberIds shrinks by
      // exactly their own uid) — used for account deletion too. Only the
      // creator can remove OTHER members, or edit the group's name/target.
      // Any current member can award a badge (badges-only change) when
      // their increment crosses the group's goal.
      allow update: if request.auth != null
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
            && request.resource.data.memberIds.removeAll([request.auth.uid])
              == resource.data.memberIds
          )
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
            && resource.data.memberIds.removeAll([request.auth.uid])
              == request.resource.data.memberIds
          )
          || (
            request.auth.uid == resource.data.createdBy
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
            && resource.data.memberIds.hasAll(request.resource.data.memberIds)
            && request.resource.data.memberIds.size() < resource.data.memberIds.size()
          )
          || (
            request.auth.uid == resource.data.createdBy
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'target'])
          )
          || (
            request.auth.uid in resource.data.memberIds
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['badges'])
          )
        );
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;

      match /members/{memberId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == memberId;
        // The group creator can remove other members' docs when deleting
        // the whole group.
        allow delete: if request.auth != null
          && request.auth.uid
            == get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy;
      }
    }
  }
}
